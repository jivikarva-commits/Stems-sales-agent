# Stems Sales Agent — environment template
# Copy to `.env` for local dev. On Render, set these in the dashboard.

# ── REQUIRED ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/stems-agents-data?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/stems-agents-data?retryWrites=true&w=majority
DB_NAME=stems-agents-data
CLAUDE_API_KEY=sk-ant-api03-xxxxx
PRIMARY_OWNER_EMAIL=your-admin@example.com

# ── INTER-SERVICE URLS ──────────────────────────────────────
# Local dev — keep as is. On Render, the Python backend gets
# WHATSAPP_AGENT_URL auto-injected from the WA service.
WHATSAPP_AGENT_URL=http://localhost:3000
EMAIL_AGENT_URL=http://localhost:3001
CALL_AGENT_URL=http://localhost:3002

# ── PORTS (local dev only) ──────────────────────────────────
PYTHON_PORT=8000
WA_PORT=3000
EMAIL_PORT=3001
CALL_PORT=3002
FRONTEND_PORT=3003

# ── OPTIONAL ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
REACT_APP_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
CORS_ORIGINS=http://localhost:3003

# Vapi (for voice calls — optional)
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# Gmail (for email agent — optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=

# YCloud WhatsApp Business API (optional, falls back to Baileys)
YCLOUD_API_KEY=
YCLOUD_WHATSAPP_NUMBER=
YCLOUD_WABA_ID=
YCLOUD_TEMPLATE_NAME=
YCLOUD_TEMPLATE_LANGUAGE=en

# Claude model override (optional)
CLAUDE_MODEL=claude-sonnet-4-20250514